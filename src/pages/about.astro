---
import Layout from '../layouts/Layout.astro';
const title = 'About Al Tair Althahbi Key Cutting — Madinat Zayed';
const description = 'Al Tair Althahbi Key Cutting L.L.C — licensed key duplication, locksmith & car key programming specialists serving Madinat Zayed & Western Region, Abu Dhabi. Trade License CN-5690039.';
---

<Layout {title} {description}>

    <section class="page-header">
        <div class="container">
            <nav class="breadcrumb" aria-label="Breadcrumb">
                <a href="/">Home</a> <span>/</span> <span data-i18n="nav-about">About</span>
            </nav>
            <h1 class="page-header__title">About <span class="text-gold">Al Tair Althahbi</span></h1>
            <p class="page-header__subtitle">Your trusted key cutting and locksmith partner in Madinat Zayed, Western Region, Abu Dhabi</p>
        </div>
    </section>

    <main class="about-page">

        <section class="about-intro">
            <div class="container">
                <div class="about-intro__grid">
                    <div class="about-intro__text">
                        <h2>Who We <span class="text-gold">Are</span></h2>
                        <p class="about-intro__lead">Al Tair Althahbi Key Cutting L.L.C - S.P.C (الطير الذهبي لنسخ المفاتيح) is a fully licensed and registered key cutting and locksmith company based in Madinat Zayed, the capital of the Al Dhafra (Western) Region of Abu Dhabi.</p>
                        <p>We specialize in professional key duplication, car key programming, locksmith services, and security solutions for residential, commercial, and automotive clients across the Western Region.</p>
                        <p>Operating from Al Marami 2 Street (MZE16), we are conveniently located to serve all communities in the Al Dhafra region, from Liwa Oasis to Sila, and from Ruwais to Habshan.</p>
                    </div>
                    <div class="about-intro__credentials">
                        <div class="credential-card reveal"><h3>✅ Licensed &amp; Registered</h3><p>Trade License CN-5690039 issued by the Abu Dhabi Department of Economic Development (ADDED).</p></div>
                        <div class="credential-card reveal"><h3>📍 Madinat Zayed Based</h3><p>Strategically located on Al Marami 2 Street (MZE16) to serve the entire Al Dhafra Region.</p></div>
                        <div class="credential-card reveal"><h3>🕐 Open 365 Days</h3><p>Every day, 8 AM – 12 Midnight, including weekends and public holidays.</p></div>
                    </div>
                </div>
            </div>
        </section>

        <section class="about-areas">
            <div class="container">
                <div class="section-header">
                    <h2 class="section-title">Areas We <span class="text-gold">Serve</span></h2>
                    <p class="section-subtitle">Mobile service available across the entire Western Region</p>
                </div>
                <div class="areas__grid">
                    <div class="area-card reveal"><h3>📍 Madinat Zayed</h3><p>Our home base — MZE16, Al Marami 2 Street. Walk-in or call ahead.</p></div>
                    <div class="area-card reveal"><h3>📍 Ghayathi</h3><p>Full locksmith &amp; key services with mobile service available.</p></div>
                    <div class="area-card reveal"><h3>📍 Ruwais</h3><p>Key duplication, car key programming &amp; emergency locksmith.</p></div>
                    <div class="area-card reveal"><h3>📍 Liwa Oasis</h3><p>Mobile locksmith reaching all Liwa communities.</p></div>
                    <div class="area-card reveal"><h3>📍 Mirfa</h3><p>Emergency locksmith for coastal communities.</p></div>
                    <div class="area-card reveal"><h3>📍 Sila</h3><p>Key replacement extending to the western border.</p></div>
                    <div class="area-card reveal"><h3>📍 Habshan</h3><p>Industrial &amp; residential locksmith services.</p></div>
                    <div class="area-card reveal"><h3>📍 Al Dhafra Region</h3><p>All Western Region communities — call for your area.</p></div>
                </div>
            </div>
        </section>

        <section class="about-expertise">
            <div class="container">
                <div class="section-header">
                    <h2 class="section-title">Our <span class="text-gold">Equipment</span> &amp; Expertise</h2>
                </div>
                <div class="expertise__content">
                    <img src="/images/macro-cutting.webp" alt="Ultra-precision CNC car key cutting at Al Tair Althahbi workshop Madinat Zayed" loading="lazy" width="800" height="400" class="img-rounded">
                    <ul class="expertise__list">
                        <li><strong>Computerized Key Cutting:</strong> High-precision digital key duplicators for exact, first-try copies.</li>
                        <li><strong>Advanced Diagnostic Tools:</strong> Professional OBD-II scanners compatible with all major vehicle brands.</li>
                        <li><strong>Transponder Cloning:</strong> Clone transponder chips for most vehicle models, no dealership needed.</li>
                        <li><strong>Comprehensive Key Blank Inventory:</strong> Thousands of blanks in stock — residential, commercial, vehicle and safe.</li>
                        <li><strong>Mobile Service Vehicle:</strong> Fully equipped van for on-site key cutting and locksmith anywhere in the region.</li>
                    </ul>
                </div>
            </div>
        </section>

        <section class="about-trust">
            <div class="container">
                <div class="section-header">
                    <h2 class="section-title">Why You Can <span class="text-gold">Trust</span> Us</h2>
                </div>
                <div class="trust__grid">
                    <div class="trust__card reveal"><span class="trust__icon">📋</span><h3>Licensed Business</h3><p>Registered with Abu Dhabi Department of Economic Development under Trade License CN-5690039.</p></div>
                    <div class="trust__card reveal"><span class="trust__icon">📍</span><h3>Physical Location</h3><p>Real shop on Al Marami 2 Street, Madinat Zayed — come visit us any day.</p></div>
                    <div class="trust__card reveal"><span class="trust__icon">🕐</span><h3>Always Available</h3><p>Open every day from 8 AM to 12 Midnight — 365 days a year.</p></div>
                    <div class="trust__card reveal"><span class="trust__icon">💰</span><h3>Fair Pricing</h3><p>Competitive, transparent rates — no hidden fees or surprise charges.</p></div>
                    <div class="trust__card reveal"><span class="trust__icon">🛡️</span><h3>Insured &amp; Professional</h3><p>Our work is guaranteed — we make it right every time.</p></div>
                    <div class="trust__card reveal"><span class="trust__icon">🗣️</span><h3>Arabic &amp; English</h3><p>Fluent in both languages — proudly serving the diverse UAE community.</p></div>
                </div>
            </div>
        </section>

    </main>

    <section class="cta-banner">
        <div class="container">
            <div class="cta-banner__content">
                <h2>Visit Us or Call — We're Here to Help</h2>
                <p>Al Marami 2 Street, Madinat Zayed. Open daily 8 AM – 12 Midnight.</p>
                <div class="cta-banner__actions">
                    <a href="tel:+971547542722" class="btn btn--white btn--lg">📞 Call +971 54 754 2722</a>
                    <a href="/contact/" class="btn btn--outline-white btn--lg">📍 Get Directions</a>
                </div>
            </div>
        </div>
    </section>

</Layout>
