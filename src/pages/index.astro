---
import Layout from '../layouts/Layout.astro';
const title = 'Professional Key Duplication & Locksmith Services in Madinat Zayed';
const description = 'Al Tair Althahbi Key Cutting — professional key duplication, emergency locksmith, car key programming & locksmith services in Madinat Zayed, Western Region, Abu Dhabi. Call +971 54 754 2722. Open daily 8 AM–12 Midnight.';
---

<Layout {title} {description}>
<main>
    <!-- ── HERO ──────────────────────────────────────────────────────── -->
    <section class="hero">
        <div class="hero__bg" style="background-image: url('/images/hero-workshop.webp');" aria-hidden="true"></div>
        <div class="hero__overlay" aria-hidden="true"></div>
        <div class="container">
            <div class="hero__content">
                <span class="hero__eyebrow" data-i18n="hero-eyebrow">Madinat Zayed — Western Region, Abu Dhabi</span>
                <h1 class="hero__title">
                    <span data-i18n="hero-title-part1">Professional</span>
                    <span class="text-gold" data-i18n="hero-title-gold1"> Key Duplication</span>
                    <span data-i18n="hero-title-and"> &amp;</span>
                    <span class="text-gold" data-i18n="hero-title-gold2"> Locksmith</span>
                    <span data-i18n="hero-title-part2"> Services</span>
                </h1>
                <p class="hero__subtitle" data-i18n="hero-subtitle">
                    Trusted key cutting, car key programming, emergency locksmith &amp; security solutions.
                    Serving <a href="https://maps.app.goo.gl/X1rvZrmEcpGMZRxK8" target="_blank" rel="noopener" style="color:var(--gold-light);text-decoration:underline;">Madinat Zayed</a>,
                    Ghayathi, Ruwais, Liwa &amp; all Western Region communities.
                </p>
                <div class="hero__actions">
                    <a href="tel:+971547542722" class="btn btn--gold btn--lg" data-i18n="hero-cta-call">📞 Call Now — +971 54 754 2722</a>
                    <a href="https://wa.me/971547542722" class="btn btn--outline-white btn--lg" target="_blank" rel="noopener noreferrer" data-i18n="hero-cta-whatsapp">💬 WhatsApp Us</a>
                </div>
                <div class="hero__trust">
                    <span data-i18n="hero-trust-1">✅ Licensed &amp; Insured</span>
                    <span data-i18n="hero-trust-2">✅ 24/7 Emergency Service</span>
                    <span data-i18n="hero-trust-3">✅ 100% Satisfaction</span>
                </div>
            </div>
        </div>
    </section>

    <!-- ── STATS BAR ─────────────────────────────────────────────────── -->
    <section class="stats-bar" aria-label="Key statistics">
        <div class="container">
            <div class="stats-bar__grid">
                <div class="stats-bar__item">
                    <span class="stats-bar__number" data-count="16" data-suffix="h">16h</span>
                    <span class="stats-bar__label" data-i18n="stat1-label">Hours Open Daily</span>
                </div>
                <div class="stats-bar__item">
                    <span class="stats-bar__number" data-count="7" data-suffix="+">7+</span>
                    <span class="stats-bar__label" data-i18n="stat2-label">Cities Served</span>
                </div>
                <div class="stats-bar__item">
                    <span class="stats-bar__number" data-count="365" data-suffix="">365</span>
                    <span class="stats-bar__label" data-i18n="stat3-label">Days a Year</span>
                </div>
                <div class="stats-bar__item">
                    <span class="stats-bar__number" data-count="6" data-suffix="+">6+</span>
                    <span class="stats-bar__label" data-i18n="stat4-label">Professional Services</span>
                </div>
            </div>
        </div>
    </section>

    <!-- ── SERVICE AREA TICKER ────────────────────────────────────────── -->
    <section class="service-area-ticker" aria-label="Service areas">
        <div class="service-area-ticker__track" aria-hidden="true">
            <span class="service-area-ticker__item" data-i18n="service-area">📍 Serving: <strong>Madinat Zayed</strong> · Ghayathi · Ruwais · Liwa Oasis · Mirfa · Sila · Habshan · Al Dhafra · Western Region, Abu Dhabi</span>
            <span class="service-area-ticker__item">📍 Serving: <strong>Madinat Zayed</strong> · Ghayathi · Ruwais · Liwa Oasis · Mirfa · Sila · Habshan · Al Dhafra · Western Region, Abu Dhabi</span>
            <span class="service-area-ticker__item">📍 Serving: <strong>Madinat Zayed</strong> · Ghayathi · Ruwais · Liwa Oasis · Mirfa · Sila · Habshan · Al Dhafra · Western Region, Abu Dhabi</span>
            <span class="service-area-ticker__item">📍 Serving: <strong>Madinat Zayed</strong> · Ghayathi · Ruwais · Liwa Oasis · Mirfa · Sila · Habshan · Al Dhafra · Western Region, Abu Dhabi</span>
        </div>
        <!-- Visually hidden accessible text -->
        <p style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0)">Serving Madinat Zayed, Ghayathi, Ruwais, Liwa Oasis, Mirfa, Sila, Habshan, Al Dhafra and all Western Region communities in Abu Dhabi.</p>
    </section>

    <!-- ── SERVICES GRID ─────────────────────────────────────────────── -->
    <section class="services" id="services">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title" data-i18n="services-title">Our <span class="text-gold">Services</span></h2>
                <p class="section-subtitle" data-i18n="services-subtitle">Comprehensive key cutting, locksmith &amp; security solutions under one roof</p>
            </div>
            <div class="services__grid">
                <article class="service-card reveal">
                    <div class="service-card__img-wrap"><img src="/images/key-duplication.webp" alt="Precision electronic key duplication at Al Tair Althahbi workshop Madinat Zayed" class="img-cover" loading="lazy" width="400" height="200"></div>
                    <div class="service-card__body">
                        <span class="service-card__icon">🔑</span>
                        <h3 class="service-card__title" data-i18n="srv1-title">Key Duplication</h3>
                        <p class="service-card__desc" data-i18n="srv1-desc">Precision key duplication for residential, commercial &amp; vehicle keys. Same-day service with OEM-quality blanks.</p>
                        <a href="/services/#key-duplication" class="service-card__link" data-i18n="svc-learn">Learn More →</a>
                    </div>
                </article>
                <article class="service-card reveal">
                    <div class="service-card__img-wrap"><img src="/images/emergency-lockout.webp" alt="24/7 emergency locksmith response in Madinat Zayed by Al Tair Althahbi" class="img-cover" loading="lazy" width="400" height="200"></div>
                    <div class="service-card__body">
                        <span class="service-card__icon">🚨</span>
                        <h3 class="service-card__title" data-i18n="srv3-title">Emergency Locksmith</h3>
                        <p class="service-card__desc" data-i18n="srv3-desc">Locked out? Broken key? 24/7 emergency locksmith. Fast response anywhere in the Western Region.</p>
                        <a href="/services/#emergency-locksmith" class="service-card__link" data-i18n="svc-learn">Learn More →</a>
                    </div>
                </article>
                <article class="service-card reveal">
                    <div class="service-card__img-wrap"><img src="/images/car-key-programming.webp" alt="Car key programming diagnostic service for all vehicles at Al Tair Althahbi Abu Dhabi" class="img-cover" loading="lazy" width="400" height="200"></div>
                    <div class="service-card__body">
                        <span class="service-card__icon">🚗</span>
                        <h3 class="service-card__title" data-i18n="srv4-title">Car Key Programming</h3>
                        <p class="service-card__desc" data-i18n="srv4-desc">Advanced car key programming, transponder, remote fobs &amp; smart keys. All makes &amp; models.</p>
                        <a href="/services/#car-key-programming" class="service-card__link" data-i18n="svc-learn">Learn More →</a>
                    </div>
                </article>
                <article class="service-card reveal">
                    <div class="service-card__img-wrap"><img src="/images/key-types.webp" alt="All car key types — standard transponder remote smart key replacement by Al Tair Althahbi" class="img-cover" loading="lazy" width="400" height="200"></div>
                    <div class="service-card__body">
                        <span class="service-card__icon">🔧</span>
                        <h3 class="service-card__title" data-i18n="srv5-title">Car Key Replacement</h3>
                        <p class="service-card__desc" data-i18n="srv5-desc">Lost or broken car keys? We replace &amp; program all types — standard, remote, transponder &amp; smart keys.</p>
                        <a href="/services/#car-key-replacement" class="service-card__link" data-i18n="svc-learn">Learn More →</a>
                    </div>
                </article>
                <article class="service-card reveal">
                    <div class="service-card__img-wrap"><img src="/images/safe-opening.webp" alt="Professional safe opening and repair by Al Tair Althahbi locksmith in Abu Dhabi" class="img-cover" loading="lazy" width="400" height="200"></div>
                    <div class="service-card__body">
                        <span class="service-card__icon">🔒</span>
                        <h3 class="service-card__title" data-i18n="srv6-title">Safe Opening &amp; Repair</h3>
                        <p class="service-card__desc" data-i18n="srv6-desc">Professional safe opening, combination change &amp; repair for home safes, office safes &amp; vaults.</p>
                        <a href="/services/#safe-opening" class="service-card__link" data-i18n="svc-learn">Learn More →</a>
                    </div>
                </article>
                <article class="service-card reveal">
                    <div class="service-card__img-wrap"><img src="/images/lock-installation.webp" alt="Deadbolt lock installation service by Al Tair Althahbi locksmith for UAE homes and offices" class="img-cover" loading="lazy" width="400" height="200"></div>
                    <div class="service-card__body">
                        <span class="service-card__icon">🏠</span>
                        <h3 class="service-card__title" data-i18n="srv7-title">Lock Installation</h3>
                        <p class="service-card__desc" data-i18n="srv7-desc">Expert installation of residential &amp; commercial locks, deadbolts, digital locks &amp; high-security systems.</p>
                        <a href="/services/#lock-installation" class="service-card__link" data-i18n="svc-learn">Learn More →</a>
                    </div>
                </article>
            </div>
        </div>
    </section>

    <!-- ── PHOTO GALLERY ─────────────────────────────────────────────── -->
    <section class="img-gallery">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">Our <span class="text-gold">Work</span> in Action</h2>
                <p class="section-subtitle">Professional key cutting &amp; locksmith services across the Western Region</p>
            </div>
            <div class="img-gallery__grid">
                <div class="img-gallery__item reveal"><img src="/images/mobile-van.webp" alt="Al Tair Althahbi mobile locksmith van serving Western Region Abu Dhabi" class="img-cover" loading="lazy" width="400" height="250"><span class="img-gallery__caption">Mobile Locksmith — All Western Region</span></div>
                <div class="img-gallery__item reveal"><img src="/images/customer-counter.webp" alt="Customer service at Al Tair Althahbi Key Cutting counter Madinat Zayed" class="img-cover" loading="lazy" width="400" height="250"><span class="img-gallery__caption">Professional Counter Service</span></div>
                <div class="img-gallery__item reveal"><img src="/images/macro-cutting.webp" alt="Ultra-precision CNC key cutting at Al Tair Althahbi workshop" class="img-cover" loading="lazy" width="400" height="250"><span class="img-gallery__caption">Precision CNC Key Cutting</span></div>
                <div class="img-gallery__item reveal"><img src="/images/night-emergency.webp" alt="24/7 night emergency car lockout response Al Tair Althahbi Abu Dhabi" class="img-cover" loading="lazy" width="400" height="250"><span class="img-gallery__caption">24/7 Night Emergency Response</span></div>
                <div class="img-gallery__item reveal"><img src="/images/key-inventory.webp" alt="Key blank inventory wall at Al Tair Althahbi Key Cutting Madinat Zayed" class="img-cover" loading="lazy" width="400" height="250"><span class="img-gallery__caption">Thousands of Key Blanks in Stock</span></div>
                <div class="img-gallery__item reveal"><img src="/images/shop-front.webp" alt="Al Tair Althahbi Key Cutting shop Al Marami 2 Street Madinat Zayed Abu Dhabi" class="img-cover" loading="lazy" width="400" height="250"><span class="img-gallery__caption">Visit Our Shop — Al Marami 2 St</span></div>
                <div class="img-gallery__item reveal"><img src="/images/smart-lock.webp" alt="Samsung digital smart lock installation Al Tair Althahbi locksmith Abu Dhabi" class="img-cover" loading="lazy" width="400" height="250"><span class="img-gallery__caption">Digital Smart Lock Installation</span></div>
                <div class="img-gallery__item reveal"><img src="/images/key-types.webp" alt="Car key types serviced by Al Tair Althahbi — standard transponder remote smart keys" class="img-cover" loading="lazy" width="400" height="250"><span class="img-gallery__caption">All Key Types — Standard to Smart</span></div>
            </div>
        </div>
    </section>

    <!-- ── WHY CHOOSE US ─────────────────────────────────────────────── -->
    <section class="why-us" id="why-us">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title" data-i18n="why-title">Why Choose <span class="text-gold">Al Tair Althahbi?</span></h2>
                <p class="section-subtitle" data-i18n="why-subtitle">Your trusted key cutting &amp; locksmith partner in the Western Region</p>
            </div>
            <div class="why-us__grid">
                <div class="why-us__card reveal"><div class="why-us__icon">🏆</div><h3 data-i18n="why1-title">Licensed &amp; Certified</h3><p data-i18n="why1-desc">Fully licensed in Abu Dhabi (CN-5690039). Professionally trained technicians you can trust.</p></div>
                <div class="why-us__card reveal"><div class="why-us__icon">⚡</div><h3 data-i18n="why2-title">Fast Response</h3><p data-i18n="why2-desc">Quick response across Madinat Zayed, Ghayathi, Ruwais &amp; all Western Region. 24/7 emergency.</p></div>
                <div class="why-us__card reveal"><div class="why-us__icon">🛠️</div><h3 data-i18n="why3-title">Advanced Equipment</h3><p data-i18n="why3-desc">State-of-the-art key cutting machines &amp; diagnostic tools for all vehicle makes &amp; models.</p></div>
                <div class="why-us__card reveal"><div class="why-us__icon">💰</div><h3 data-i18n="why4-title">Competitive Pricing</h3><p data-i18n="why4-desc">Fair, transparent pricing with no hidden fees. Quality work at budget-friendly rates.</p></div>
                <div class="why-us__card reveal"><div class="why-us__icon">🕐</div><h3 data-i18n="why5-title">Open Daily — Long Hours</h3><p data-i18n="why5-desc">Every day, 8:00 AM to 12:00 Midnight — including weekends &amp; holidays.</p></div>
                <div class="why-us__card reveal"><div class="why-us__icon">🤝</div><h3 data-i18n="why6-title">All Western Region</h3><p data-i18n="why6-desc">From Sila to Mirfa, Liwa to Habshan — we serve the entire Al Dhafra region.</p></div>
            </div>
        </div>
    </section>

    <!-- ── TESTIMONIALS ──────────────────────────────────────────────── -->
    <section class="testimonials" id="testimonials">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">What Our <span class="text-gold">Customers Say</span></h2>
                <p class="section-subtitle">Real reviews from customers across the Western Region, Abu Dhabi</p>
            </div>
            <div class="testimonials__grid">
                <div class="testimonial-card reveal">
                    <div class="testimonial-card__stars" aria-label="5 stars">★★★★★</div>
                    <p class="testimonial-card__text">"Very professional service! I lost my Toyota Hilux key and they made a new programmed key in less than an hour. Excellent work and fair price. Highly recommended for anyone in Madinat Zayed."</p>
                    <div class="testimonial-card__author"><strong>Ahmed Al Dhaheri</strong><span>Car Key Programming — Madinat Zayed</span></div>
                </div>
                <div class="testimonial-card reveal">
                    <div class="testimonial-card__stars" aria-label="5 stars">★★★★★</div>
                    <p class="testimonial-card__text">"I called them at 11 PM when I locked my keys inside the car. They arrived within 30 minutes and opened it without any damage. Amazing 24/7 emergency service — saved my night!"</p>
                    <div class="testimonial-card__author"><strong>Fatima Al Mansoori</strong><span>Emergency Lockout — Ghayathi</span></div>
                </div>
                <div class="testimonial-card reveal">
                    <div class="testimonial-card__stars" aria-label="5 stars">★★★★★</div>
                    <p class="testimonial-card__text">"Duplicated all my home and office keys in minutes. Very accurate copies — all worked perfectly first try. Best key shop in the Western Region. Fast, professional and affordable!"</p>
                    <div class="testimonial-card__author"><strong>Mohammed Al Kaabi</strong><span>Key Duplication — Madinat Zayed</span></div>
                </div>
            </div>
        </div>
    </section>

    <!-- ── CTA BANNER ────────────────────────────────────────────────── -->
    <section class="cta-banner">
        <div class="container">
            <div class="cta-banner__content">
                <h2 data-i18n="cta-title">🔑 Locked Out? Need a Key Made?</h2>
                <p data-i18n="cta-subtitle">Fast, reliable key cutting &amp; locksmith service — available daily 8 AM to 12 Midnight</p>
                <div class="cta-banner__actions">
                    <a href="tel:+971547542722" class="btn btn--white btn--lg" data-i18n="cta-call">📞 Call +971 54 754 2722</a>
                    <a href="https://wa.me/971547542722" class="btn btn--outline-white btn--lg" target="_blank" rel="noopener noreferrer" data-i18n="cta-whatsapp">💬 WhatsApp Us</a>
                </div>
            </div>
        </div>
    </section>

    <!-- ── FAQ ───────────────────────────────────────────────────────── -->
    <section class="faq" id="faq">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title" data-i18n="faq-title">Frequently Asked <span class="text-gold">Questions</span></h2>
                <p class="section-subtitle" data-i18n="faq-subtitle">Common questions about our key cutting &amp; locksmith services</p>
            </div>
            <div class="faq__list">
                <details class="faq__item"><summary class="faq__question" data-i18n="faq1-q">What areas do you serve?</summary><div class="faq__answer"><p data-i18n="faq1-a">Based in Madinat Zayed, we serve the entire Western Region: Madinat Zayed, Ghayathi, Ruwais, Liwa, Mirfa, Sila, Habshan &amp; more.</p></div></details>
                <details class="faq__item"><summary class="faq__question" data-i18n="faq2-q">Do you provide emergency locksmith services?</summary><div class="faq__answer"><p data-i18n="faq2-a">Yes! 24/7 emergency locksmith. Call +971 54 754 2722 — fast response anywhere in the Western Region.</p></div></details>
                <details class="faq__item"><summary class="faq__question" data-i18n="faq3-q">Can you program car keys for all brands?</summary><div class="faq__answer"><p data-i18n="faq3-a">Yes — Toyota, Nissan, Mitsubishi, Honda, Hyundai, Kia, Ford, Chevrolet, Mercedes, BMW, Audi &amp; more.</p></div></details>
                <details class="faq__item"><summary class="faq__question" data-i18n="faq4-q">What key types can you duplicate?</summary><div class="faq__answer"><p data-i18n="faq4-a">All types — residential, office, padlock, vehicle (standard &amp; transponder), safe keys &amp; high-security.</p></div></details>
                <details class="faq__item"><summary class="faq__question" data-i18n="faq5-q">How quickly can you arrive for an emergency?</summary><div class="faq__answer"><p data-i18n="faq5-a">15–30 min in Madinat Zayed, 30–60 min for Ghayathi, Ruwais, Mirfa. Call for your exact area.</p></div></details>
                <details class="faq__item"><summary class="faq__question" data-i18n="faq6-q">Are you open on Fridays &amp; public holidays?</summary><div class="faq__answer"><p data-i18n="faq6-a">Yes — 365 days a year, 8 AM – 12 Midnight, including Fridays &amp; all public holidays.</p></div></details>
            </div>
        </div>
    </section>
</main>
</Layout>
