---
import Layout from '../layouts/Layout.astro';
const title = 'Key Cutting & Locksmith Services in Madinat Zayed';
const description = 'Full range of key cutting, locksmith, car key programming, emergency locksmith & security services by Al Tair Althahbi Key Cutting in Madinat Zayed, Western Region, Abu Dhabi. Call +971 54 754 2722.';
---

<Layout {title} {description}>

    <section class="page-header">
        <div class="container">
            <nav class="breadcrumb" aria-label="Breadcrumb">
                <a href="/">Home</a> <span>/</span> <span data-i18n="nav-services">Services</span>
            </nav>
            <h1 class="page-header__title" data-i18n="svc-page-title">Our <span class="text-gold">Services</span></h1>
            <p class="page-header__subtitle" data-i18n="svc-page-subtitle">Professional key cutting, locksmith &amp; security solutions for homes, businesses &amp; vehicles across the Western Region</p>
        </div>
    </section>

    <main class="service-details">

        <section class="service-section" id="key-duplication">
            <div class="container"><div class="service-section__grid"><div class="service-section__content">
                <span class="service-section__icon">🔑</span>
                <h2 class="service-section__title" data-i18n="srv1-title">Key Duplication <span class="text-gold">Service</span></h2>
                <p class="service-section__lead">Fast, accurate key duplication for residential, commercial &amp; automotive keys in Madinat Zayed.</p>
                <img src="/images/key-duplication.webp" alt="Precision electronic key duplication machine at Al Tair Althahbi workshop Madinat Zayed" class="service-section__img" loading="lazy" width="800" height="400">
                <p>At Al Tair Althahbi, we use precision computerized key cutting machines to produce exact duplicates of your keys. Same-day service with OEM-quality key blanks across all major brands.</p>
                <h3>Key Types We Duplicate:</h3>
                <ul>
                    <li>Residential door keys — all lock brands</li>
                    <li>Commercial &amp; office keys — master key systems</li>
                    <li>Padlock &amp; cabinet keys</li>
                    <li>Vehicle keys — standard, transponder &amp; high-security</li>
                    <li>Safe keys &amp; restricted keys</li>
                    <li>Mortise keys, tubular keys &amp; dimple keys</li>
                </ul>
                <a href="tel:+971547542722" class="btn btn--gold">📞 Call for Key Duplication</a>
            </div></div></div>
        </section>

        <section class="service-section service-section--alt" id="emergency-locksmith">
            <div class="container"><div class="service-section__grid"><div class="service-section__content">
                <span class="service-section__icon">🚨</span>
                <h2 class="service-section__title" data-i18n="srv3-title">Emergency <span class="text-gold">Locksmith</span></h2>
                <p class="service-section__lead">24/7 emergency locksmith — fast response when you're locked out or in distress.</p>
                <img src="/images/emergency-lockout.webp" alt="24/7 emergency locksmith by Al Tair Althahbi — professional lockout response in Madinat Zayed" class="service-section__img" loading="lazy" width="800" height="400">
                <h3>Emergency Services:</h3>
                <ul>
                    <li><strong>Home Lockouts:</strong> Locked out? We'll get you back in without damage</li>
                    <li><strong>Car Lockouts:</strong> Keys locked inside? We can help</li>
                    <li><strong>Office Lockouts:</strong> Emergency access for businesses</li>
                    <li><strong>Broken Key Extraction:</strong> Key snapped? We remove &amp; replace</li>
                </ul>
                <div class="emergency-cta">
                    <p>🚨 <strong>Emergency? Call Now — Available 24/7</strong></p>
                    <a href="tel:+971547542722" class="btn btn--gold btn--lg">📞 +971 54 754 2722</a>
                </div>
            </div></div></div>
        </section>

        <section class="service-section" id="car-key-programming">
            <div class="container"><div class="service-section__grid"><div class="service-section__content">
                <span class="service-section__icon">🚗</span>
                <h2 class="service-section__title" data-i18n="srv4-title">Car Key <span class="text-gold">Programming</span></h2>
                <p class="service-section__lead">Advanced car key programming for all makes &amp; models — transponder, remote &amp; smart keys.</p>
                <img src="/images/car-key-programming.webp" alt="Professional car key programming and OBD2 diagnostic service for all vehicles at Al Tair Althahbi" class="service-section__img" loading="lazy" width="800" height="400">
                <h3>Car Key Types We Program:</h3>
                <ul>
                    <li><strong>Transponder Keys:</strong> Chip keys with immobilizer programming</li>
                    <li><strong>Remote Key Fobs:</strong> Keyless entry remote programming</li>
                    <li><strong>Smart Keys:</strong> Push-to-start key programming</li>
                </ul>
                <p>Toyota, Nissan, Mitsubishi, Honda, Hyundai, Kia, Ford, Chevrolet, GMC, Mercedes, BMW, Audi, Lexus &amp; more.</p>
                <a href="tel:+971547542722" class="btn btn--gold">📞 Inquire About Car Key Programming</a>
            </div></div></div>
        </section>

        <section class="service-section service-section--alt" id="car-key-replacement">
            <div class="container"><div class="service-section__grid"><div class="service-section__content">
                <span class="service-section__icon">🔧</span>
                <h2 class="service-section__title" data-i18n="srv5-title">Car Key <span class="text-gold">Replacement</span></h2>
                <p class="service-section__lead">Lost, stolen or broken car keys? We replace &amp; program all types.</p>
                <img src="/images/key-types.webp" alt="All car key types replaced and programmed by Al Tair Althahbi — standard transponder remote fob and smart keys" class="service-section__img" loading="lazy" width="800" height="400">
                <ul>
                    <li>Lost all keys? We can generate new keys from your vehicle's VIN</li>
                    <li>Need a spare? We duplicate &amp; program additional keys</li>
                    <li>Broken key? We extract, cut new blade &amp; transfer electronics</li>
                </ul>
                <a href="tel:+971547542722" class="btn btn--gold">📞 Replace Your Car Key</a>
            </div></div></div>
        </section>

        <section class="service-section" id="safe-opening">
            <div class="container"><div class="service-section__grid"><div class="service-section__content">
                <span class="service-section__icon">🔒</span>
                <h2 class="service-section__title" data-i18n="srv6-title">Safe Opening <span class="text-gold">&amp; Repair</span></h2>
                <p class="service-section__lead">Professional safe opening, combination recovery &amp; repair services.</p>
                <img src="/images/safe-opening.webp" alt="Professional safe opening and repair service by Al Tair Althahbi locksmith in Abu Dhabi" class="service-section__img" loading="lazy" width="800" height="400">
                <ul>
                    <li>Safe opening — combination lost or forgotten</li>
                    <li>Safe repair — jammed bolts, broken handles, dial issues</li>
                    <li>Combination change &amp; reset</li>
                    <li>Non-destructive entry whenever possible</li>
                </ul>
                <a href="tel:+971547542722" class="btn btn--gold">📞 Safe Opening Assistance</a>
            </div></div></div>
        </section>

        <section class="service-section service-section--alt" id="lock-installation">
            <div class="container"><div class="service-section__grid"><div class="service-section__content">
                <span class="service-section__icon">🏠</span>
                <h2 class="service-section__title" data-i18n="srv7-title">Lock <span class="text-gold">Installation</span></h2>
                <p class="service-section__lead">Expert lock installation for residential, commercial &amp; industrial properties.</p>
                <img src="/images/lock-installation.webp" alt="Professional deadbolt and mortise lock installation by certified Al Tair Althahbi locksmith" class="service-section__img" loading="lazy" width="800" height="400">
                <ul>
                    <li>Deadbolts &amp; deadlatches — single &amp; double cylinder</li>
                    <li>Digital &amp; keypad locks — PIN, RFID &amp; fingerprint</li>
                    <li>Smart locks — WiFi/Bluetooth, app-controlled</li>
                    <li>High-security locks — pick-resistant cylinders</li>
                </ul>
                <a href="tel:+971547542722" class="btn btn--gold">📞 Schedule Lock Installation</a>
            </div></div></div>
        </section>

        <section class="service-section" id="locksmith">
            <div class="container"><div class="service-section__grid"><div class="service-section__content">
                <span class="service-section__icon">🔐</span>
                <h2 class="service-section__title" data-i18n="srv2-title">Locksmith <span class="text-gold">Services</span></h2>
                <p class="service-section__lead">Complete locksmith solutions — installation, repair, rekeying &amp; security upgrades.</p>
                <img src="/images/smart-lock.webp" alt="Professional locksmith services — digital and mechanical lock installation by Al Tair Althahbi in Madinat Zayed" class="service-section__img" loading="lazy" width="800" height="400">
                <p>Our certified locksmiths handle every lock and security need across the Western Region.</p>
                <h3>Our Locksmith Services Include:</h3>
                <ul>
                    <li><strong>Lock Repair:</strong> Fixing jammed, broken or worn-out locks</li>
                    <li><strong>Rekeying:</strong> Change lock cylinders — keep your existing hardware</li>
                    <li><strong>Digital &amp; Smart Locks:</strong> Installation &amp; programming</li>
                    <li><strong>Master Key Systems:</strong> Design &amp; implementation for businesses</li>
                </ul>
                <a href="tel:+971547542722" class="btn btn--gold">📞 Get Locksmith Help</a>
            </div></div></div>
        </section>

        <section class="service-section service-section--alt" id="access-control">
            <div class="container"><div class="service-section__grid"><div class="service-section__content">
                <span class="service-section__icon">🛡️</span>
                <h2 class="service-section__title" data-i18n="srv9-title">Access Control <span class="text-gold">Systems</span></h2>
                <p class="service-section__lead">Electronic access control, intercom &amp; security systems for businesses &amp; compounds.</p>
                <img src="/images/access-control.webp" alt="RFID card and keypad access control system installation for commercial properties by Al Tair Althahbi" class="service-section__img" loading="lazy" width="800" height="400">
                <ul>
                    <li>Standalone keypad &amp; card access systems</li>
                    <li>Networked multi-door access control</li>
                    <li>Biometric fingerprint access</li>
                    <li>Intercom systems — audio &amp; video</li>
                </ul>
                <a href="tel:+971547542722" class="btn btn--gold">📞 Discuss Access Control</a>
            </div></div></div>
        </section>

    </main>

    <section class="cta-banner">
        <div class="container">
            <div class="cta-banner__content">
                <h2 data-i18n="cta-title">🔑 Need a Key Made or Lock Fixed?</h2>
                <p>We're here every day, 8 AM to 12 Midnight.</p>
                <div class="cta-banner__actions">
                    <a href="tel:+971547542722" class="btn btn--white btn--lg" data-i18n="cta-call">📞 Call +971 54 754 2722</a>
                    <a href="https://wa.me/971547542722" class="btn btn--outline-white btn--lg" target="_blank" rel="noopener noreferrer" data-i18n="cta-whatsapp">💬 WhatsApp</a>
                </div>
            </div>
        </div>
    </section>

</Layout>
